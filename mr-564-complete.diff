+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.util.Optional;
+import org.junit.jupiter.api.Test;
+import org.springframework.amqp.core.AmqpAdmin;
+import org.springframework.amqp.core.Queue;
+import org.springframework.amqp.rabbit.config.SimpleRabbitListenerContainerFactory;
+import org.springframework.amqp.rabbit.connection.ConnectionFactory;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.context.SpringBootTest.WebEnvironment;
+import org.springframework.test.annotation.DirtiesContext;
+import org.springframework.test.annotation.DirtiesContext.ClassMode;
+import org.springframework.test.context.TestPropertySource;
+import org.springframework.test.context.bean.override.mockito.MockitoBean;
+import pl.santander.utils.jwt.JwtTokenUtil;
+import pl.santander.vas.dictionaries.mors.adapter.mors.MorsQueueListener;
+import pl.santander.vas.infrastructure.rabbitmq.QueueConfiguration;
+import pl.santander.vas.tokenvalidation.JWTTokenUtilConfiguration;
+
+/**
+ * Skip-path survival integration test (S-04 / FR-010), the access-control dimension that
+ * {@link CodeFlowContractIT} (auth-header body shape) cannot exercise: it proves that
+ * GET /api/v1/context/user-details remains a <b>public no-auth skip path</b> on Spring Boot 4.
+ *
+ * <p>Runs over a real embedded Tomcat ({@code webEnvironment = RANDOM_PORT}) so the Servlet 6
+ * container populates {@code getServletPath()} with the full path, the JWT-filter antPattern
+ * skip matches, and the request reaches the controller without any auth headers ÔÇö returning 200.
+ * (Under MockMvc the skip silently fails, an artifact documented in
+ * {@code baseline-provenance.md}.)
+ *
+ * <p>This is a deliberately separate application context (real Tomcat, distinct cache key); it is
+ * exempt from the single-{@code Started}-line invariant that governs the MockMvc IT family.
+ */
+@SpringBootTest(webEnvironment = WebEnvironment.RANDOM_PORT, properties = "spring.profiles.active=test")
+@DirtiesContext(classMode = ClassMode.AFTER_CLASS)
+@TestPropertySource(properties = {
+    "spring.datasource.url=jdbc:h2:mem:codeFlowSkipPathIT;MODE=PostgreSQL;DATABASE_TO_LOWER=true;INIT=CREATE SCHEMA IF NOT EXISTS vassme\\\\;SET SCHEMA vassme",
+    "keycloak-session-config.as-customer-realm.realm=" + CUSTOMER_REALM,
+    "keycloak-session-config.as-partner-realm.realm=" + PARTNER_REALM,
+    "keycloak-session-config.as-realm.realm=" + CUSTOMER_REALM,
+    "keycloak-session-config.authorized-party-token-pdc=" + AUTHORIZED_PARTY_TOKEN_PDC,
+    "keycloak-session-config.keycloak-clients[0].partner-key=" + PARTNER_KEY,
+    "keycloak-session-config.keycloak-clients[0].client-id=" + PARTNER_CLIENT_ID
+})
+class CodeFlowSkipPathIT {
+
+    @Value("${local.server.port}")
+    private int port;
+
+    // --- Infrastructure mocks (mirrors ProtectedEndpointITBase so the context boots) ---
+    @MockitoBean
+    private QueueConfiguration queueConfiguration;
+    @MockitoBean
+    @Qualifier("morsAmqpAdmin")
+    private AmqpAdmin morsAmqpAdmin;
+    @MockitoBean
+    @Qualifier("morsConnectionFactory")
+    private ConnectionFactory morsConnectionFactory;
+    @MockitoBean
+    @Qualifier("morsRabbitContainerFactory")
+    private SimpleRabbitListenerContainerFactory morsRabbitContainerFactory;
+    @MockitoBean
+    @Qualifier("morsQueue")
+    private Queue morsQueue;
+    @MockitoBean
+    private MorsQueueListener morsQueueListener;
+    @MockitoBean
+    private JWTTokenUtilConfiguration jwtTokenUtilConfiguration;
+    @MockitoBean
+    private JwtTokenUtil jwtTokenUtil;
+
+    @MockitoBean
+    private KeyCloakSessionService keyCloakSessionService;
+
+    @Test
+    void userDetails_noAuthHeaders_returns200_skipPathSurvivesBoot4() throws Exception {
+        when(keyCloakSessionService.getKeyCloakSession(any(), any(), any()))
+            .thenReturn(Optional.of(new KeyCloakSessionDTO("probe-code", "0001234567")));
+
+        HttpResponse<String> response = HttpClient.newHttpClient().send(
+            HttpRequest.newBuilder()
+                .uri(URI.create("http://localhost:" + port
+                    + "/api/v1/context/user-details?code=probe-code&client_id=partner-client&grant_type=CLIENT_CREDENTIALS"))
+                .GET()
+                .build(),
+            HttpResponse.BodyHandlers.ofString());
+
+        assertThat(response.statusCode())
+            .as("user-details must stay a public no-auth skip path on Boot 4")
+            .isEqualTo(200);
+        assertThat(response.body()).contains("\"sign_in_session_id\":\"probe-code\"");
+    }
+}
