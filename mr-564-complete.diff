+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.context.TestConfiguration;
+import org.springframework.boot.jdbc.test.autoconfigure.AutoConfigureTestDatabase;
+import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;
+import org.springframework.boot.restclient.RestTemplateBuilder;
+import org.springframework.cache.CacheManager;
+import org.springframework.cache.support.NoOpCacheManager;
+import org.springframework.context.annotation.Bean;
+import org.springframework.jdbc.core.JdbcTemplate;
+import org.springframework.test.annotation.DirtiesContext;
+import org.springframework.test.annotation.DirtiesContext.ClassMode;
+import org.springframework.test.context.ActiveProfiles;
+import org.springframework.test.context.DynamicPropertyRegistry;
+import org.springframework.test.context.DynamicPropertySource;
+import pl.santander.vas.prelimits.Prelimit;
+import pl.santander.vas.prelimits.PrelimitsRepository;
+
+@DataJpaTest(properties = {
+    "spring.liquibase.change-log=classpath:changelog/postgresql/db.changelog-master.yaml",
+    "spring.liquibase.contexts=test",
+    "spring.cache.type=none"
+})
+@AutoConfigureTestDatabase(replace = AutoConfigureTestDatabase.Replace.NONE)
+@ActiveProfiles("test")
+@DirtiesContext(classMode = ClassMode.AFTER_CLASS)
+class LiquibaseJpaRegressionSmokeTest {
+
+    @DynamicPropertySource
+    static void h2DataSource(DynamicPropertyRegistry registry) {
+        registry.add("spring.datasource.url", () -> "jdbc:h2:mem:liquibaseJpaRegressionSmoke;MODE=PostgreSQL;DATABASE_TO_LOWER=true;INIT=CREATE SCHEMA IF NOT EXISTS vassme\\;SET SCHEMA vassme");
+        registry.add("spring.datasource.username", () -> "sa");
+        registry.add("spring.datasource.password", () -> "sa");
+        registry.add("spring.datasource.driver-class-name", () -> "org.h2.Driver");
+    }
+
+    @Autowired
+    private DataSource dataSource;
+    @Autowired
+    private JdbcTemplate jdbcTemplate;
+    @Autowired
+    private PrelimitsRepository prelimitsRepository;
+
+    @Test
+    void shouldApplyPostgresqlChangelogOnH2AndPersistRepresentativeEntity() throws SQLException {
+        try (var conn = dataSource.getConnection()) {
+            assertThat(conn.getMetaData().getURL()).startsWith("jdbc:h2:");
+        }
+        Integer changelogRows = jdbcTemplate.queryForObject("select count(*) from databasechangelog", Integer.class);
+        Prelimit prelimit = new Prelimit();
+        prelimit.setCif("0000000011");
+        prelimit.setPrelimitValue(13);
+        prelimit.setStartDate(LocalDate.of(2025, 3, 5));
+        prelimit.setEndDate(LocalDate.of(2025, 5, 7));
+        prelimit.setCreatedBy("regression-test");
+        prelimit.setCreationDate(LocalDateTime.of(2025, 3, 5, 12, 0));
+        prelimit.setIsDeleted(false);
+        prelimit.setLastModifiedBy("regression-test");
+        prelimit.setLastModificationDate(LocalDateTime.of(2025, 3, 5, 12, 0));
+
+        prelimitsRepository.saveAndFlush(prelimit);
+
+        assertThat(changelogRows).isNotNull().isPositive();
+        assertThat(prelimitsRepository.findByCifAndIsDeletedFalse("0000000011"))
+            .isPresent()
+            .get()
+            .extracting(Prelimit::getPrelimitValue)
+            .isEqualTo(13);
+    }
+
+    @TestConfiguration
+    static class RestTemplateBuilderConfig {
+
+        @Bean
+        RestTemplateBuilder restTemplateBuilder() {
+            return new RestTemplateBuilder();
+        }
+
+        @Bean
+        CacheManager cacheManager() {
+            return new NoOpCacheManager();
+        }
+    }
+}
