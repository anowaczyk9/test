@@ -0,0 +1,129 @@
+package pl.santander.vas.tokenvalidation;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.mockito.Mockito.doReturn;
+import static org.mockito.Mockito.never;
+import static org.mockito.Mockito.verify;
+import static org.mockito.Mockito.verifyNoInteractions;
+import static org.mockito.Mockito.when;
+
+import jakarta.servlet.http.HttpServletResponse;
+import java.lang.reflect.Method;
+import org.aspectj.lang.ProceedingJoinPoint;
+import org.junit.jupiter.api.AfterEach;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+import org.springframework.http.HttpStatus;
+import org.springframework.mock.web.MockHttpServletRequest;
+import org.springframework.mock.web.MockHttpServletResponse;
+import org.springframework.web.context.request.RequestContextHolder;
+import org.springframework.web.context.request.ServletRequestAttributes;
+import pl.santander.utils.jwt.JwtContext;
+import pl.santander.utils.jwt.JwtTokenUtil;
+
+@ExtendWith(MockitoExtension.class)
+class SecureWithTokensRegressionSafetyNetTest {
+
+    @Mock
+    private CekeContextSource cekeContextSource;
+    @Mock
+    private JwtTokenUtil jwtTokenUtil;
+    @Mock
+    private ProceedingJoinPoint proceedingJoinPoint;
+
+    @AfterEach
+    void tearDown() {
+        RequestContextHolder.resetRequestAttributes();
+    }
+
+    @Test
+    void invalidKeycloakTokenReturns401ForProtectedTokenEndpointRequestPath() throws Throwable {
+        KeycloakAndCekeTokenValidationAspect aspect = new KeycloakAndCekeTokenValidationAspect(cekeContextSource, jwtTokenUtil);
+        MockHttpServletResponse response = bindResponseToTokenEndpointRequest();
+        doReturn(jwtContext(false)).when(jwtTokenUtil).validateToken("invalid-keycloak-token");
+
+        Object result = aspect.validate(
+            proceedingJoinPoint,
+            annotation("keycloakOnly"),
+            "Bearer invalid-keycloak-token",
+            "unused-token-v2"
+        );
+
+        assertThat(result).isNull();
+        assertThat(response.getStatus()).isEqualTo(HttpStatus.UNAUTHORIZED.value());
+        assertThat(response.getErrorMessage()).isEqualTo("Token is invalid");
+        verify(proceedingJoinPoint, never()).proceed();
+        verifyNoInteractions(cekeContextSource);
+    }
+
+    @Test
+    void validKeycloakTokenProceedsForKeycloakOnlyAnnotation() throws Throwable {
+        KeycloakAndCekeTokenValidationAspect aspect = new KeycloakAndCekeTokenValidationAspect(cekeContextSource, jwtTokenUtil);
+        bindResponseToTokenEndpointRequest();
+        doReturn(jwtContext(true)).when(jwtTokenUtil).validateToken("valid-keycloak-token");
+        when(proceedingJoinPoint.proceed()).thenReturn("controller-result");
+
+        Object result = aspect.validate(
+            proceedingJoinPoint,
+            annotation("keycloakOnly"),
+            "Bearer valid-keycloak-token",
+            "unused-token-v2"
+        );
+
+        assertThat(result).isEqualTo("controller-result");
+        verify(proceedingJoinPoint).proceed();
+        verifyNoInteractions(cekeContextSource);
+    }
+
+    @Test
+    void defaultSecureWithTokensAnnotationChecksCekeBeforeKeycloak() throws Throwable {
+        KeycloakAndCekeTokenValidationAspect aspect = new KeycloakAndCekeTokenValidationAspect(cekeContextSource, jwtTokenUtil);
+        MockHttpServletResponse response = bindResponseToTokenEndpointRequest();
+        when(cekeContextSource.isValid("invalid-token-v2", "Bearer valid-keycloak-token")).thenReturn(false);
+
+        Object result = aspect.validate(
+            proceedingJoinPoint,
+            annotation("cekeAndKeycloak"),
+            "Bearer valid-keycloak-token",
+            "invalid-token-v2"
+        );
+
+        assertThat(result).isNull();
+        assertThat(response.getStatus()).isEqualTo(HttpServletResponse.SC_UNAUTHORIZED);
+        verifyNoInteractions(jwtTokenUtil);
+        verify(proceedingJoinPoint, never()).proceed();
+    }
+
+    private MockHttpServletResponse bindResponseToTokenEndpointRequest() {
+        MockHttpServletRequest request = new MockHttpServletRequest("GET", "/api/v1/context/token/INFAKT");
+        MockHttpServletResponse response = new MockHttpServletResponse();
+        RequestContextHolder.setRequestAttributes(new ServletRequestAttributes(request, response));
+        return response;
+    }
+
+    private SecureWithTokens annotation(String methodName) throws NoSuchMethodException {
+        Method method = ProtectedMethods.class.getDeclaredMethod(methodName, String.class, String.class);
+        return method.getAnnotation(SecureWithTokens.class);
+    }
+
+    private JwtContext jwtContext(boolean valid) {
+        JwtContext jwtContext = org.mockito.Mockito.mock(JwtContext.class);
+        when(jwtContext.isValid()).thenReturn(valid);
+        return jwtContext;
+    }
+
+    private static class ProtectedMethods {
+
+        @SecureWithTokens(tokens = {TokenType.KEYCLOAK_TOKEN})
+        void keycloakOnly(String authorizationHeader, String tokenV2header) {
+            // Intentionally empty: this method is never executed in tests; we reflect only on @SecureWithTokens metadata.
+        }
+
+        @SecureWithTokens
+        void cekeAndKeycloak(String authorizationHeader, String tokenV2header) {
+            // Intentionally empty: this method is never executed in tests; we reflect only on @SecureWithTokens metadata.
+        }
+    }
+}
