+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.mockito.Mockito;
+import org.springframework.core.io.ClassPathResource;
+import org.springframework.http.HttpHeaders;
+import org.springframework.test.web.servlet.MvcResult;
+import pl.santander.utils.jwt.JwtContext;
+import pl.santander.vas.infrastructure.ProtectedEndpointITBase;
+
+/**
+ * Full-context integration test proving the CODE flow user-details contract (S-04 / FR-010):
+ * GET /api/v1/context/user-details maintains unchanged HTTP status codes and snake_case
+ * {@link KeyCloakSessionDTO} JSON serialization after Spring Boot 4 migration.
+ *
+ * <p>This is the body-shape dimension, asserted on the shared cached MOCK context. The request
+ * reaches the controller via valid customer auth headers: under full-context MockMvc the
+ * JWT-filter antPattern skip does not match (a MockMvc artifact ÔÇö {@code getServletPath()} is
+ * empty), so relying on the skip would 401. The response body is controller-produced and
+ * identical either way. The orthogonal access-control dimension (that user-details stays a
+ * public no-auth skip path on Boot 4) is proven separately by {@link CodeFlowSkipPathIT} over
+ * real Tomcat.
+ *
+ * <p>The body is asserted byte-for-byte against a Boot 3.5-captured JSON baseline.
+ */
+class CodeFlowContractIT extends ProtectedEndpointITBase {
+
+    @BeforeEach
+    void setUpTokenStubs() {
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(AUTHORIZATION_TOKEN);
+        when(jwtTokenUtil.isAudienceCorrect(AUTHORIZATION_TOKEN, List.of(AUTHORIZED_PARTY_TOKEN_PDC)))
+            .thenReturn(true);
+
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(CUSTOMER_AUTHORIZED_PARTY_TOKEN);
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "iss"))
+            .thenReturn(Optional.of("https://as.test/auth/realms/" + CUSTOMER_REALM));
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "channel_tp"))
+            .thenReturn(Optional.of("test-channel"));
+    }
+
+    // --- GET /api/v1/context/user-details: happy path (snake_case body shape) ---
+
+    @Test
+    void userDetails_validClientCredentialsLookup_returns200WithStableJson() throws Exception {
+        when(keyCloakSessionService.getKeyCloakSession("valid-code", GratTypeEnum.CLIENT_CREDENTIALS, "partner-client"))
+            .thenReturn(Optional.of(new KeyCloakSessionDTO("valid-session-code", "0001234567")));
+
+        MvcResult result = mockMvc.perform(get("/api/v1/context/user-details")
+                .param("code", "valid-code")
+                .param("client_id", "partner-client")
+                .param("grant_type", "CLIENT_CREDENTIALS")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isOk())
+            .andReturn();
+
+        assertThat(result.getResponse().getContentAsString())
+            .isEqualTo(readFixture("regression-proof-safety-net/keycloak/user-details-client-credentials-stable-json-contract.json"));
+    }
+
+    // --- 401: service returns empty Optional (status-only) ---
+
+    @Test
+    void userDetails_emptyServiceResult_returns401() throws Exception {
+        when(keyCloakSessionService.getKeyCloakSession("invalid-code", GratTypeEnum.CLIENT_CREDENTIALS, "unknown-client"))
+            .thenReturn(Optional.empty());
+
+        mockMvc.perform(get("/api/v1/context/user-details")
+                .param("code", "invalid-code")
+                .param("client_id", "unknown-client")
+                .param("grant_type", "CLIENT_CREDENTIALS")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isUnauthorized());
+    }
+
+    // --- 400: unsupported grant_type fails enum bind before the service (status-only) ---
+
+    @Test
+    void userDetails_unsupportedGrantType_returns400() throws Exception {
+        mockMvc.perform(get("/api/v1/context/user-details")
+                .param("code", "valid-code")
+                .param("client_id", "partner-client")
+                .param("grant_type", "PASSWORD")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isBadRequest());
+    }
+
+    // --- Helpers ---
+
+    private JwtContext validJwtContext() {
+        JwtContext ctx = Mockito.mock(JwtContext.class);
+        when(ctx.isValid()).thenReturn(true);
+        return ctx;
+    }
+
+    private String readFixture(String path) throws Exception {
+        return new String(new ClassPathResource(path).getInputStream().readAllBytes(), StandardCharsets.UTF_8).trim();
+    }
+}
