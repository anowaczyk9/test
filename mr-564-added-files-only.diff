+import org.mockito.Mockito;
+import org.springframework.core.io.ClassPathResource;
+import org.springframework.http.HttpHeaders;
+import org.springframework.http.MediaType;
+import org.springframework.test.web.servlet.MvcResult;
+import pl.santander.utils.jwt.JwtContext;
+import pl.santander.vas.infrastructure.ProtectedEndpointITBase;
+
+/**
+ * Full-context integration test proving the AOC contract (S-04 / FR-012):
+ * POST /api/v1/authorizations maintains unchanged HTTP status codes and {@link AocData}
+ * JSON serialization after Spring Boot 4 migration.
+ *
+ * <p>Must live in {@code pl.santander.vas.aoc} because it stubs the package-private
+ * {@link AocService#initializeAuthorization}. The happy-path body is asserted byte-for-byte
+ * against a Boot 3.5-captured baseline; negatives are status-only (empirically empty-bodied).
+ */
+class AocContractIT extends ProtectedEndpointITBase {
+
+    @BeforeEach
+    void setUpTokenStubs() {
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(AUTHORIZATION_TOKEN);
+        when(jwtTokenUtil.isAudienceCorrect(AUTHORIZATION_TOKEN, List.of(AUTHORIZED_PARTY_TOKEN_PDC)))
+            .thenReturn(true);
+
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(CUSTOMER_AUTHORIZED_PARTY_TOKEN);
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "iss"))
+            .thenReturn(Optional.of("https://as.test/auth/realms/" + CUSTOMER_REALM));
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "channel_tp"))
+            .thenReturn(Optional.of("test-channel"));
+    }
+
+    // --- POST /api/v1/authorizations: happy path ---
+
+    @Test
+    void authorize_validCustomerTokens_returns200WithStableJson() throws Exception {
+        when(aocService.initializeAuthorization(any(), any()))
+            .thenReturn(AocData.builder().id("aoc-auth-id-123").digest("aoc-digest-abc").build());
+
+        MvcResult result = mockMvc.perform(post("/api/v1/authorizations")
+                .contentType(MediaType.APPLICATION_JSON)
+                .content("{\"key\":\"AGREEMENTS\"}")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isOk())
+            .andReturn();
+
+        assertThat(result.getResponse().getContentAsString())
+            .isEqualTo(readFixture("regression-proof-safety-net/aoc/post-authorizations-stable-json-contract.json"));
+    }
+
+    // --- 400: missing @NotNull key fails bean validation before the service (status-only) ---
+
+    @Test
+    void authorize_missingKey_returns400() throws Exception {
+        mockMvc.perform(post("/api/v1/authorizations")
+                .contentType(MediaType.APPLICATION_JSON)
+                .content("{}")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isBadRequest());
+    }
+
+    // --- 401: no auth headers (status-only) ---
+
+    @Test
+    void authorize_missingAuthorizationToken_returns401() throws Exception {
+        mockMvc.perform(post("/api/v1/authorizations")
+                .contentType(MediaType.APPLICATION_JSON)
+                .content("{\"key\":\"AGREEMENTS\"}"))
+            .andExpect(status().isUnauthorized());
+    }
+
+    // --- Helpers ---
+
+    private JwtContext validJwtContext() {
+        JwtContext ctx = Mockito.mock(JwtContext.class);
+        when(ctx.isValid()).thenReturn(true);
+        return ctx;
+    }
+
+    private String readFixture(String path) throws Exception {
+        return new String(new ClassPathResource(path).getInputStream().readAllBytes(), StandardCharsets.UTF_8).trim();
+    }
+}
