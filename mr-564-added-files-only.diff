+ */
+class AgreementsContractIT extends ProtectedEndpointITBase {
+
+    @BeforeEach
+    void setUpTokenStubs() {
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(AUTHORIZATION_TOKEN);
+        when(jwtTokenUtil.isAudienceCorrect(AUTHORIZATION_TOKEN, List.of(AUTHORIZED_PARTY_TOKEN_PDC)))
+            .thenReturn(true);
+
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(CUSTOMER_AUTHORIZED_PARTY_TOKEN);
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "iss"))
+            .thenReturn(Optional.of("https://as.test/auth/realms/" + CUSTOMER_REALM));
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "channel_tp"))
+            .thenReturn(Optional.of("test-channel"));
+    }
+
+    // --- GET /api/v1/agreements: populated record (field order + enum rendering) ---
+
+    @Test
+    void agreements_populatedRecord_returns200WithStableJson() throws Exception {
+        when(agreementsService.getAgreements(any(), any(), any()))
+            .thenReturn(List.of(AgreementObject.builder()
+                .key("MARKETING")
+                .name("Marketing Agreement")
+                .status(AgreementStatus.ACCEPTED)
+                .version(3)
+                .content("Full agreement text")
+                .oldContent("Previous agreement text")
+                .build()));
+
+        MvcResult result = performAgreementsRequest();
+
+        assertThat(result.getResponse().getContentAsString())
+            .isEqualTo(readFixture("regression-proof-safety-net/agreements/get-agreements-stable-json-contract.json"));
+    }
+
+    // --- GET /api/v1/agreements: null oldContent (null-inclusion via use-jackson2-defaults) ---
+
+    @Test
+    void agreements_nullOldContent_returns200WithNullIncluded() throws Exception {
+        when(agreementsService.getAgreements(any(), any(), any()))
+            .thenReturn(List.of(AgreementObject.builder()
+                .key("MARKETING")
+                .name("Marketing Agreement")
+                .status(AgreementStatus.NEW_AVAILABLE)
+                .version(1)
+                .content("Full agreement text")
+                .oldContent(null)
+                .build()));
+
+        MvcResult result = performAgreementsRequest();
+
+        assertThat(result.getResponse().getContentAsString())
+            .isEqualTo(readFixture("regression-proof-safety-net/agreements/get-agreements-null-oldcontent-stable-json-contract.json"));
+    }
+
+    // --- 401: no auth headers (status-only) ---
+
+    @Test
+    void agreements_missingAuthorizationToken_returns401() throws Exception {
+        mockMvc.perform(get("/api/v1/agreements")
+                .header(HttpHeaders.ACCEPT_LANGUAGE, "en"))
+            .andExpect(status().isUnauthorized());
+    }
+
+    // --- Helpers ---
+
+    private MvcResult performAgreementsRequest() throws Exception {
+        return mockMvc.perform(get("/api/v1/agreements")
+                .header(HttpHeaders.ACCEPT_LANGUAGE, "en")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isOk())
+            .andReturn();
+    }
+
+    private JwtContext validJwtContext() {
+        JwtContext ctx = Mockito.mock(JwtContext.class);
+        when(ctx.isValid()).thenReturn(true);
+        return ctx;
+    }
+
+    private String readFixture(String path) throws Exception {
+        return new String(new ClassPathResource(path).getInputStream().readAllBytes(), StandardCharsets.UTF_8).trim();
+    }
+}
