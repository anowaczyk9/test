+/**
+ * Shared test infrastructure for full-context integration tests that exercise
+ * protected VAS endpoints. Declares the common {@code @MockitoBean} set and
+ * {@code @TestPropertySource} so subclasses share a single cached Spring
+ * ApplicationContext (no double boot).
+ *
+ * Does NOT extend {@link SpringBootTestBase} to avoid inheriting
+ * {@code @DirtiesContext(classMode = AFTER_CLASS)} which would evict the
+ * cached context between subclass ITs.
+ */
+@SpringBootTest(properties = "spring.profiles.active=test")
+@AutoConfigureMockMvc
+@TestPropertySource(properties = {
+    // This context is intentionally NOT @DirtiesContext (cached across the two ITs to avoid a
+    // double boot), so its H2 connection pool stays open for the whole JVM and keeps the shared
+    // mem DB alive. Isolate it under a dedicated mem DB name so a later @DirtiesContext repository
+    // test (SpringBootTestBase) does not hit "databasechangelog already exists" when its own
+    // Liquibase run targets the still-live shared DB.
+    "spring.datasource.url=jdbc:h2:mem:protectedEndpointIT;MODE=PostgreSQL;DATABASE_TO_LOWER=true;INIT=CREATE SCHEMA IF NOT EXISTS vassme\\\\;SET SCHEMA vassme",
+    "keycloak-session-config.as-customer-realm.realm=" + CUSTOMER_REALM,
+    "keycloak-session-config.as-partner-realm.realm=" + PARTNER_REALM,
