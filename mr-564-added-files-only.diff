+
+@NoArgsConstructor(access = AccessLevel.PRIVATE)
+public final class AuthTestFixtures {
+
+    public static final String AUTHORIZED_PARTY_TOKEN_PDC = "test-authorized-party-vassme";
+    public static final String CUSTOMER_REALM = "TEST-CUSTOMER-REALM";
+    public static final String PARTNER_REALM = "TEST-PARTNER-REALM";
+    public static final String CUSTOMER_CLIENT_ID = "test-customer-client";
+    public static final String PARTNER_CLIENT_ID = "test-partner-client";
+    public static final String PARTNER_KEY = "TEST-PARTNER";
+    public static final KeyCloakClientConfig PARTNER_CLIENT = new KeyCloakClientConfig(PARTNER_KEY, PARTNER_CLIENT_ID);
+
+    public static final String AUTHORIZATION_TOKEN = jwt("""
+        {"iss":"https://as.test/auth/realms/TEST-AUTH-REALM","aud":"test-authorized-party-vassme","client_id":"test-authorized-party-vassme"}
+        """);
+    public static final String CUSTOMER_AUTHORIZED_PARTY_TOKEN = jwt("""
+        {"iss":"https://as.test/auth/realms/TEST-CUSTOMER-REALM","client_id":"test-customer-client","channel_tp":"test-channel","secCtx":{"customer_nik":1001,"customer_cif":2001,"user_nik":1002,"user_cif":2002,"sign_in_session_id":"customer-session","profile_id":33,"application_id":18}}
+        """);
+    public static final String PARTNER_AUTHORIZED_PARTY_TOKEN = jwt("""
+        {"iss":"https://as.test/auth/realms/TEST-PARTNER-REALM","client_id":"test-partner-client","sign_in_session_id":"partner-session-code","preferred_username":"service-account-partner"}
+        """);
+    public static final String PREPARED_CONTEXT_HEADER = Base64.getEncoder().encodeToString("""
+        {"userId":"prepared-user","channelId":"test-channel","companyCif":"prepared-company","individualCif":"prepared-individual"}
+        """.getBytes(StandardCharsets.UTF_8));
+
+    public static UserContext customerUserContext() {
+        return UserContext.builder()
+            .userId("1002")
+            .channelId("test-channel")
+            .companyCif("0000002001")
+            .individualCif("0000002002")
+            .ownerId("1001")
+            .build();
+    }
+
+    public static UserContext partnerUserContext() {
+        return UserContext.builder()
+            .userId("partner-user")
+            .channelId("test-channel")
+            .companyCif("partner-company")
+            .individualCif("partner-individual")
+            .ownerId("partner-owner")
+            .build();
+    }
+
+    public static UserContext preparedContextUserContext() {
+        return UserContext.builder()
+            .userId("prepared-user")
+            .channelId("test-channel")
+            .companyCif("prepared-company")
+            .individualCif("prepared-individual")
+            .build();
+    }
+
+    private static String jwt(String payload) {
+        return encode("""
+            {"alg":"HS256","typ":"JWT"}
+            """)
+            + "."
+            + encode(payload.strip())
+            + "."
+            + encode("synthetic-signature");
+    }
+
+    private static String encode(String value) {
+        return Base64.getUrlEncoder()
+            .withoutPadding()
+            .encodeToString(value.strip().getBytes(StandardCharsets.UTF_8));
+    }
+}
diff --git a/src/test/java/pl/santander/vas/tokenvalidation/SecureWithTokensRegressionSafetyNetTest.java b/src/test/java/pl/santander/vas/tokenvalidation/SecureWithTokensRegressionSafetyNetTest.java
