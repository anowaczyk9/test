+
+/**
+ * Full-context integration test pinning the BigDecimal serialization contract (S-06):
+ * GET /api/infakt/customer renders a money amount ({@link MoneyInfakt#getValue()})
+ * with unchanged numeric formatting after the Spring Boot 4 migration.
+ *
+ * <p>BigDecimal number rendering (scale preservation, trailing zeros, plain vs.
+ * scientific notation) is partly governed by jackson-core's {@code writeNumber}
+ * rather than jackson-databind defaults, so the global {@code use-jackson2-defaults}
+ * proof does not necessarily cover it. This test asserts byte-equality against a
+ * fixture captured from a genuine Spring Boot 3.5.13 render (commit 8ea55be2) of
+ * {@code new BigDecimal("1234.50")} ÔÇö a value with non-trivial scale and a
+ * significant trailing zero ÔÇö proving Boot 4 produces the identical wire format.
+ *
+ * <p>This IT adds {@code @MockitoBean InFaktService} which is package-private and
+ * therefore cannot live in {@link ProtectedEndpointITBase}. The extra mock forks
+ * Spring's context cache, so we give the forked context its own H2 in-memory DB
+ * name ({@code bigdecimalIT}) to avoid a Liquibase collision with the shared
+ * {@code protectedEndpointIT} context.
+ */
+@TestPropertySource(properties =
+    "spring.datasource.url=jdbc:h2:mem:bigdecimalIT;MODE=PostgreSQL;DATABASE_TO_LOWER=true;INIT=CREATE SCHEMA IF NOT EXISTS vassme\\\\;SET SCHEMA vassme"
+)
+class InFaktCustomerBigDecimalContractIT extends ProtectedEndpointITBase {
+
+    @MockitoBean
+    private InFaktService inFaktService;
+
+    @BeforeEach
+    void setUpTokenStubs() {
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(AUTHORIZATION_TOKEN);
+        when(jwtTokenUtil.isAudienceCorrect(AUTHORIZATION_TOKEN, List.of(AUTHORIZED_PARTY_TOKEN_PDC)))
+            .thenReturn(true);
+
+        doReturn(validJwtContext()).when(jwtTokenUtil).validateToken(CUSTOMER_AUTHORIZED_PARTY_TOKEN);
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "iss"))
+            .thenReturn(Optional.of("https://as.test/auth/realms/" + CUSTOMER_REALM));
+        when(jwtTokenUtil.get(CUSTOMER_AUTHORIZED_PARTY_TOKEN, "channel_tp"))
+            .thenReturn(Optional.of("test-channel"));
+    }
+
+    @Test
+    void infaktCustomer_bigDecimalMoney_returns200WithStableJson() throws Exception {
+        when(inFaktService.getInfaktCustomer(any())).thenReturn(regressionCustomer());
+
+        MvcResult result = mockMvc.perform(get("/api/infakt/customer")
+                .header(HttpHeaders.AUTHORIZATION, "Bearer " + AUTHORIZATION_TOKEN)
+                .header("Authorized-Party-Token", CUSTOMER_AUTHORIZED_PARTY_TOKEN))
+            .andExpect(status().isOk())
+            .andReturn();
+
+        assertThat(result.getResponse().getContentAsString())
+            .isEqualTo(readFixture(
+                "regression-proof-safety-net/partners/infakt-customer-bigdecimal-stable-json-contract.json"));
+    }
+
+    // --- Helpers ---
+
+    private JwtContext validJwtContext() {
+        JwtContext ctx = Mockito.mock(JwtContext.class);
+        when(ctx.isValid()).thenReturn(true);
+        return ctx;
+    }
+
+    private Customer regressionCustomer() {
+        return Customer.builder()
+            .customerAccounts(List.of(AccountHeaderInfakt.builder()
+                .availableFunds(MoneyInfakt.builder()
+                    .currencyCode("PLN")
+                    .value(new BigDecimal("1234.50"))
+                    .build())
+                .currencyCode("PLN")
+                .number("PL61109010140000071219812874")
+                .build()))
+            .build();
+    }
+
+    private String readFixture(String path) throws Exception {
+        return new String(new ClassPathResource(path).getInputStream().readAllBytes(), StandardCharsets.UTF_8).trim();
+    }
+}
