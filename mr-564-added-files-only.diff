+package pl.santander.vas.infrastructure.logs;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import org.junit.jupiter.api.Test;
+
+class CustomValueMaskerTest {
+
+    @Test
+    void shouldFullyMaskConfiguredStringAndNumberFields() {
+        CustomValueMasker masker = new CustomValueMasker();
+        masker.setAnonymize(true);
+        masker.setFullyAnonymizedStringFields("secret");
+        masker.setFullyAnonymizedNumberFields("documentNumber");
+
+        Object masked = masker.mask(null, """
+            {"secret":"visible-test-value","documentNumber":123456789,"other":"unchanged"}""");
+
+        assertThat(masked).isEqualTo("""
+            {"secret":"******************","documentNumber":*********,"other":"unchanged"}""");
+    }
+
+    @Test
+    void shouldPartiallyMaskConfiguredFieldsLeavingLastThreeCharacters() {
+        CustomValueMasker masker = new CustomValueMasker();
+        masker.setAnonymize(true);
+        masker.setPartiallyAnonymizedStringFields("pesel");
+
+        Object masked = masker.mask(null, """
+            {"pesel":"12345678901","other":"unchanged"}""");
+
+        assertThat(masked).isEqualTo("""
+            {"pesel":"********901","other":"unchanged"}""");
+    }
+
+    @Test
+    void shouldLeaveMessageUnchangedWhenAnonymizeIsDisabled() {
+        CustomValueMasker masker = new CustomValueMasker();
+        masker.setAnonymize(false);
+        masker.setFullyAnonymizedStringFields("secret");
+        String message = """
+            {"secret":"visible-test-value","other":"unchanged"}""";
+
+        assertThat(masker.mask(null, message)).isEqualTo(message);
+    }
+}
